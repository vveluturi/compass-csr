{
  "version": 2,
  "buildCommand": "cd compass-csr && npm install && npm run build",
  "outputDirectory": "compass-csr/dist",
  "functions": {
    "api/anthropic.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
    {
      "src": "/api/anthropic",
      "dest": "/api/anthropic.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
